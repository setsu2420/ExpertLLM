# ===========================================
# ExpertLLM-V3 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# cp .env.example .env
# ===========================================

# ---------- LLM API 密钥 ----------
# Gemini API Key (从 https://aistudio.google.com/apikey 获取)
GEMINI_API_KEY=your-gemini-api-key-here

# OpenAI API Key (从 https://platform.openai.com/api-keys 获取)
OPENAI_API_KEY=sk-your-openai-api-key-here

# SiliconFlow API (从 https://siliconflow.cn 获取)
SILICON_URL=https://api.siliconflow.cn/v1/chat/completions
SILICON_KEY=sk-your-siliconflow-key-here

# ---------- LLM 重试配置 ----------
LLM_STREAM_RETRY_MAX=3
LLM_STREAM_RETRY_BASE_DELAY=1

# ---------- 应用配置 ----------
HOST=0.0.0.0
PORT=7100
DEBUG=False
MAX_THREAD_MESSAGES=30
TRENDING_BOARD_SIZE=10

# ---------- MySQL 配置 ----------
MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_DATABASE=expertllm-db
MYSQL_USER=expertllm_user
MYSQL_PASSWORD=change-me-user-password
SQLALCHEMY_DATABASE_URI=mysql+pymysql://expertllm_user:change-me-user-password@mysql:3306/expertllm-db?charset=utf8mb4

# ---------- Redis 配置 ----------
REDIS_URL=
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_ENABLED=true
REDIS_PUBLIC_TTL_SECONDS=604800
REDIS_PUBLIC_LIST_MAX=300
REDIS_PUBLIC_LIST_PREFIX=public:list
REDIS_PUBLIC_HASH_PREFIX=public:msg
REDIS_PUBLIC_CHANNEL_PREFIX=public:major

# ---------- 安全配置 ----------
# 生产环境务必生成强随机值: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-random-secret-key
SECURE_SOCKETS=true

# ---------- Session 配置 ----------
SESSION_TOKEN_PREFIX=session:token
SESSION_TOKEN_TTL_SECONDS=604800

# ---------- 嵌入与语义热点 ----------
EMBEDDING_BACKEND=silicon
SILICON_EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
QUESTION_EMBEDDING_LOOKBACK_DAYS=7
QUESTION_EMBEDDING_MAX_SAMPLES=10000
SIM_THRESHOLD=0.6
QUESTION_TRENDING_TOP_K=10
QUESTION_TRENDING_INTERVAL_SECONDS=21600
QUESTION_TRENDING_DECAY=0.02

# ---------- 系统提示词（可选） ----------
# SYSTEM_PROMPT=使用中文，有学术性且逻辑严密不失创造力地回答。
