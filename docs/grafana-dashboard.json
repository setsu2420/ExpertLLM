{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "hide": true,
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "2.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" }
  ],
  "editable": true,
  "gnetId": null,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "type": "stat",
      "title": "Cache Hit Rate (5m)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(app_cache_hits_total[5m])) / (sum(rate(app_cache_hits_total[5m])) + sum(rate(app_cache_misses_total[5m])))",
          "refId": "A",
          "legendFormat": "hit_rate"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "decimals": 1 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal", "textMode": "value", "colorMode": "value" },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 0 }
    },
    {
      "type": "gauge",
      "title": "Public Messages Cache Hit (5m)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(app_cache_hits_total{cache_name=\"public_messages\"}[5m])) / (sum(rate(app_cache_hits_total{cache_name=\"public_messages\"}[5m])) + sum(rate(app_cache_misses_total{cache_name=\"public_messages\"}[5m])))",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 }, "overrides": [] },
      "options": { "showThresholdLabels": false, "showThresholdMarkers": true },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 0 }
    },
    {
      "type": "timeseries",
      "title": "Cache Hit/Miss Rate (5m)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "rate(app_cache_hits_total[5m])", "refId": "A", "legendFormat": "hits" },
        { "expr": "rate(app_cache_misses_total[5m])", "refId": "B", "legendFormat": "misses" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 }
    },
    {
      "type": "timeseries",
      "title": "HTTP QPS by Path (5m)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "sum by (path)(rate(app_http_requests_total[5m]))", "refId": "A", "legendFormat": "{{path}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 }
    },
    {
      "type": "timeseries",
      "title": "HTTP P95 Latency by Path (5m)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, path)(rate(app_http_request_duration_seconds_bucket[5m])))",
          "refId": "A",
          "legendFormat": "{{path}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 3 }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 }
    },
    {
      "type": "timeseries",
      "title": "HTTP P99 Latency by Path (5m)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le, path)(rate(app_http_request_duration_seconds_bucket[5m])))",
          "refId": "A",
          "legendFormat": "{{path}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 3 }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 }
    },
    {
      "type": "stat",
      "title": "LLM Success Rate (5m)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(app_llm_calls_total{status=\"success\"}[5m])) / sum(rate(app_llm_calls_total[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "decimals": 1 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 22 }
    },
    {
      "type": "stat",
      "title": "Socket.IO Connections",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "app_socketio_connections", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 0 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 22 }
    },
    {
      "type": "timeseries",
      "title": "LLM Call Rate by Provider/Model (5m)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (provider, model)(rate(app_llm_calls_total[5m]))",
          "refId": "A",
          "legendFormat": "{{provider}}/{{model}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 }
    },
    {
      "type": "timeseries",
      "title": "LLM Avg Duration by Provider/Model (5m)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (provider, model)(rate(app_llm_call_duration_seconds_sum[5m])) / sum by (provider, model)(rate(app_llm_call_duration_seconds_count[5m]))",
          "refId": "A",
          "legendFormat": "{{provider}}/{{model}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 3 }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 }
    },
    {
      "type": "timeseries",
      "title": "DB QPS by Source (5m)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "sum by (source)(rate(app_db_queries_total[5m]))", "refId": "A", "legendFormat": "{{source}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 36 }
    },
    {
      "type": "timeseries",
      "title": "Sync P95 Duration by Job (5m)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, job)(rate(app_sync_duration_seconds_bucket[5m])))",
          "refId": "A",
          "legendFormat": "{{job}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 3 }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 36 }
    },
    {
      "type": "timeseries",
      "title": "Sync Failures Rate (5m)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "sum by (job)(rate(app_sync_failures_total[5m]))", "refId": "A", "legendFormat": "{{job}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 44 }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 36,
  "style": "dark",
  "tags": ["expertllm"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": { "refresh_intervals": ["5s", "10s", "30s", "1m", "5m"] },
  "timezone": "",
  "title": "ExpertLLM-V3 Metrics",
  "version": 1
}
